ecified protocols, ensuring no single-character words or roots were included (PROTOCOL 7).","input_words":["ካሜሮናዊውን","የአባጃሌውን","ልጠላሽ","ዳርቦሜዳ","ብርጌድና","የኤሌና","ከመድፎች","ተሰልፍው","ሁኔናታ","ባያዩአቸውም","ሞክሮኝ","ሲያይልባት","ኦፕኒንግ","ሬይኖልድስ","እየተፈራገጥኩ","ከጭቁኗ","ሲፈልገውና","ኦርኪዶችን","እንስማማበት","የስራህ","ሊያደምቁት","ክታባታቸውን","የማይለሳለስ","ሀሰብን","ሌፔንን","ሰውጭ","ያስጠናነው","በአረብኛዋ","በርሚሉ","ትደፋዋለች"],"batch_number":null,"batch_label":null,"model_version":"gemini-2.5-flash"},{"id":"6516342d-8fc0-4f2c-a2d0-09bb725db31e","created_at":"2026-03-04T09:50:42.232314+00:00","word":null,"source_file":"rare_words_19/chunk_0494.txt","batch_index":0,"words":[{"pos":"Noun","root":"ምግባር","word":"የምግባርህ","synonyms":["conduct","behavior","ethics","morality","character"],"importance":7},{"pos":"Verb","root":"ማተም","word":"እንደታተመ","synonyms":["as it was printed","as it was published","according to what was printed"],"importance":7},{"pos":"Verb","root":"መጥቀስ","word":"የጠቀሰው","synonyms":["that he mentioned","what he cited"],"importance":8},{"pos":"Verb","root":"መጥቀስ","word":"በጥቀስ","synonyms":["by mentioning","by citing","in a quote"],"importance":8},{"pos":"Verb","root":"መርዳት","word":"እንደረዱህ","synonyms":["as they helped you","that they assisted you"],"importance":7},{"pos":"Adjective","root":"ድሮ","word":"የድሮ","synonyms":["old","ancient","former"],"importance":7},{"pos":"Verb","root":"መፍለጥ","word":"መፍለጥ","synonyms":["to split","to cleave","to slice","to crack"],"importance":7},{"pos":"Adjective","root":"ልማት","word":"የልማታዊው","synonyms":["of the developmental","of the progressive"],"importance":7},{"pos":"Verb","root":"ማስቀጠል","word":"እንድታስቀጥለው","synonyms":["so that you continue it","for you to continue it"],"importance":8},{"pos":"Verb","root":"መዋጥ","word":"ባልዋጥኩ","synonyms":["if I had not swallowed","if I did not swallow"],"importance":7},{"pos":"Verb","root":"መግደል","word":"ቢገሉኝ","synonyms":["if they kill me","even if they kill me"],"importance":7},{"pos":"Noun","root":"ጊልዶፍ","word":"ጊልዶፍ","synonyms":["Geldof (proper noun)"],"importance":6},{"pos":"Pronoun","root":"ይሄ","word":"ይሂኔ","synonyms":["this one","this is it"],"importance":6},{"pos":"Verb","root":"መስራት","word":"ተሰርተን","synonyms":["having been made","having been built","having worked"],"importance":7},{"pos":"Verb","root":"ማስከተል","word":"ስለሚያስከትሉባት","synonyms":["because they cause her","because they bring upon her"],"importance":8},{"pos":"Noun","root":"ኤግዚቢት","word":"ለኤግዚቢት","synonyms":["for exhibit","for exhibition"],"importance":6},{"pos":"Noun","root":"ራመር","word":"ራመር","synonyms":["Ramer (proper noun)"],"importance":5},{"pos":"Verb","root":"መሰማራት","word":"ስለምንሰማራበት","synonyms":["because we are deployed in it","because we are engaged in it","about which we are engaged"],"importance":8},{"pos":"Verb","root":"ማብጀት","word":"አብጂ","synonyms":["prepare","arrange","budget"],"importance":7},{"pos":"Verb","root":"ማስፋፋት","word":"ሰፋፍቼ","synonyms":["having widened","having expanded","having broadened"],"importance":7},{"pos":"Verb","root":"መጠገብ","word":"ጠገብሽ","synonyms":["you (f.sg.) are full","you (f.sg.) are satisfied"],"importance":7},{"pos":"Verb","root":"ማከነውን","word":"ያከነውናል","synonyms":["it makes us useless","it wastes us","it renders us futile"],"importance":8},{"pos":"Noun","root":"አለመጣጣም","word":"ያለመጣጣሙ","synonyms":["the incompatibility","the inconsistency","the mismatch","the disproportion"],"importance":8},{"pos":"Verb","root":"መከፋት","word":"የተከፋሁበት","synonyms":["the place I was upset","the reason I was disappointed","where I was sad"],"importance":8},{"pos":"Noun","root":"ሥት","word":"ሥቱን","synonyms":["the six","six (definite)"],"importance":6},{"pos":"Verb","root":"ማበርከት","word":"ያበረከተላቸው","synonyms":["that he contributed to them","what he offered them","what he provided them"],"importance":8},{"pos":"Noun","root":"ነፍስ","word":"የነፍሳችንን","synonyms":["of our souls","our lives (definite)"],"importance":7},{"pos":"Noun","root":"ስትሮዚ","word":"ስትሮዚ","synonyms":["Strozzi (proper noun)"],"importance":5},{"pos":"Verb","root":"ማስፈራራት","word"